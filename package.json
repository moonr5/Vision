{
  "name": "sgu-logistics",
  "version": "1.0.0",
  "description": "SGU Logistics & Telemetry Dashboard",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "jest --runInBand",
    "test:server": "jest tests/server.test.js --runInBand",
    "test:database": "jest tests/database --runInBand",
    "lint": "eslint server.js database/*.js tests/**/*.js login.js",
    "lint:fix": "eslint server.js database/*.js tests/**/*.js login.js --fix",
    "format": "prettier --write \"server.js\" \"database/*.js\" \"tests/**/*.js\" \"login.js\"",
    "format:check": "prettier --check \"server.js\" \"database/*.js\" \"tests/**/*.js\" \"login.js\""
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mqtt": "^5.3.4",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "fake-indexeddb": "^6.0.0",
    "jest": "^29.7.0",
    "jsdom": "^24.1.3",
    "prettier": "^3.4.2",
    "sql.js": "^1.12.0"
  }
}
