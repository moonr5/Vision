# PostgreSQL connection string — Railway provides this automatically
# when you add a PostgreSQL service to your project.
DATABASE_URL=postgresql://user:password@host:5432/database

# Port — Railway sets this automatically, no need to change it.
PORT=3000

# ── Backend engine URLs (Railway private networking) ──────────────────────────
# These connect the Node.js server to the Python AI microservices.
# Leave blank to disable that engine — the system degrades gracefully.

# URL of the Python AI backend (Gemini-powered fleet analysis + Telegram bot).
PYTHON_AI_URL=https://your-python-service.railway.internal

# URL of the Route Optimization Engine (AI-driven route scoring, behaviour-aware
# driver-route pairing, and 4-stage report pipeline).
ROUTE_ENGINE_URL=https://your-route-engine.railway.internal

# URL of the Scale Engine (28-engine intelligence platform: stream bus,
# time-series analytics, CEP, digital twin, anomaly detection, predictive
# maintenance, AI/ML models, RAG, knowledge graph, edge-cloud sync, and
# federated learning).
SCALE_ENGINE_URL=https://your-scale-engine.railway.internal

# Gemini API key — used by the Python AI backend for fleet analysis and reports.
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Telegram bot token — from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# (Optional) Restrict the bot to a single chat ID.
# Leave blank to allow any chat to interact with the bot.
TELEGRAM_CHAT_ID=
